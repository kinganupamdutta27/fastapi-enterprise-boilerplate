# ═══════════════════════════════════════════════════════════════════════
# Application
# ═══════════════════════════════════════════════════════════════════════
APP_NAME=FastAPI Production Template
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
CORS_ORIGINS=*

# ═══════════════════════════════════════════════════════════════════════
# Database (PostgreSQL via PgBouncer)
# ═══════════════════════════════════════════════════════════════════════
DATABASE_HOST=localhost
DATABASE_PORT=6432
DATABASE_USER=app_user
DATABASE_PASSWORD=app_secret
DATABASE_NAME=app_db
DATABASE_DIRECT_PORT=5432

# ═══════════════════════════════════════════════════════════════════════
# Connection Pool (app-side — PgBouncer multiplexes)
# ═══════════════════════════════════════════════════════════════════════
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_POOL_MAX_INACTIVE_LIFETIME=300
DB_COMMAND_TIMEOUT=60

# ═══════════════════════════════════════════════════════════════════════
# Timeouts (milliseconds — server-side via SET)
# ═══════════════════════════════════════════════════════════════════════
DB_STATEMENT_TIMEOUT=5000
DB_IDLE_IN_TRANSACTION_TIMEOUT=10000

# ═══════════════════════════════════════════════════════════════════════
# Circuit Breaker
# ═══════════════════════════════════════════════════════════════════════
CB_FAIL_MAX=5
CB_TIMEOUT_DURATION=30

# ═══════════════════════════════════════════════════════════════════════
# Retry
# ═══════════════════════════════════════════════════════════════════════
DB_RETRY_ATTEMPTS=3

# ═══════════════════════════════════════════════════════════════════════
# Docker port overrides (avoids conflicts with local services)
# ═══════════════════════════════════════════════════════════════════════
POSTGRES_HOST_PORT=5433
PGBOUNCER_HOST_PORT=6432
REDIS_HOST_PORT=6380
RABBITMQ_HOST_PORT=5672
RABBITMQ_UI_HOST_PORT=15672

# ═══════════════════════════════════════════════════════════════════════
# Redis
# ═══════════════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6380/0

# ═══════════════════════════════════════════════════════════════════════
# RabbitMQ
# ═══════════════════════════════════════════════════════════════════════
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_PREFETCH_COUNT=10

# ═══════════════════════════════════════════════════════════════════════
# Kafka
# ═══════════════════════════════════════════════════════════════════════
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=app-consumer-group

# ═══════════════════════════════════════════════════════════════════════
# Elasticsearch / ELK
# ═══════════════════════════════════════════════════════════════════════
ELASTICSEARCH_URL=http://localhost:9200

# ═══════════════════════════════════════════════════════════════════════
# GenAI / LLM
# ═══════════════════════════════════════════════════════════════════════
OPENAI_API_KEY=
LLM_MODEL_NAME=gpt-4o
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=

# ═══════════════════════════════════════════════════════════════════════
# Security
# ═══════════════════════════════════════════════════════════════════════
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
API_KEY_HEADER=X-API-Key
